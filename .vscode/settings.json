{
  "latex-workshop.latex.recipes": [
    {
      "name": "xelatex2",
      "tools": ["xelatex", "xelatex", "cleanAux"]
    }
  ],
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.clean.fileTypes": [
    "*.aux",
    "*.bbl",
    "*.blg",
    "*.idx",
    "*.ind",
    "*.lof",
    "*.lot",
    "*.out",
    "*.toc",
    "*.acn",
    "*.acr",
    "*.alg",
    "*.glg",
    "*.glo",
    "*.gls",
    "*.ist",
    "*.fls",
    "*.log",
    "*.fdb_latexmk",
    "*.pdf",
    "src/*.aux"
  ],
  "latex-workshop.latex.tools": [
    {
      "name": "xelatex",
      "command": "xelatex",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "%DOC%"
      ]
    },
    {
      "name": "cleanAux",
      "command": "bash",
      "args": ["-c", "rm -f ./src/*.aux"]
    }
  ],
  "latex-workshop.latex.autoClean.run": "onBuilt"
}
